{
  "publisher": "lexatang",
  "name": "vscode-forks-sync",
  "displayName": "Fork Sync",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "description": "Synchronize settings, keybindings and extensions across VSCode forks with smart per-key merge strategies.",
  "author": "lexatang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LexaTang/vscode-forks-sync"
  },
  "bugs": {
    "url": "https://github.com/LexaTang/vscode-forks-sync/issues"
  },
  "keywords": [
    "vscode",
    "cursor",
    "windsurf",
    "vscodium",
    "settings",
    "keybindings",
    "extensions",
    "sync"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "res/icon.png",
  "files": [
    "dist/*",
    "res/*",
    "LICENSE.md",
    "README.md"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vscode-forks-sync.syncProfile",
    "onCommand:vscode-forks-sync.syncSettings",
    "onCommand:vscode-forks-sync.syncKeybindings",
    "onCommand:vscode-forks-sync.syncExtensions"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscode-forks-sync.syncProfile",
        "title": "Sync Everything",
        "category": "Fork Sync",
        "icon": "$(sync)"
      },
      {
        "command": "vscode-forks-sync.syncSettings",
        "title": "Sync Settings",
        "category": "Fork Sync",
        "icon": "$(settings-gear)"
      },
      {
        "command": "vscode-forks-sync.syncKeybindings",
        "title": "Sync Keybindings",
        "category": "Fork Sync",
        "icon": "$(keyboard)"
      },
      {
        "command": "vscode-forks-sync.syncExtensions",
        "title": "Sync Extensions",
        "category": "Fork Sync",
        "icon": "$(extensions)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Fork Sync",
      "properties": {
        "vscode-forks-sync.storagePath": {
          "type": "string",
          "description": "The local directory used to store shared sync data between IDE forks.",
          "default": "~/.vscode-forks-sync"
        },
        "vscode-forks-sync.autoSync": {
          "type": "boolean",
          "description": "Automatically sync on startup.",
          "default": true
        },
        "vscode-forks-sync.promptOnAutoSync": {
          "type": "boolean",
          "description": "Show a confirmation prompt before auto-syncing on startup.",
          "default": true
        },
        "vscode-forks-sync.promptOnExtensionSync": {
          "type": "boolean",
          "description": "Show a confirmation prompt before applying extension changes.",
          "default": true
        },
        "vscode-forks-sync.settings.mergeMode": {
          "type": "string",
          "enum": [
            "override",
            "merge"
          ],
          "enumDescriptions": [
            "Whole-file override: whichever IDE has the newest file mtime wins entirely.",
            "Per-key merge: each key is individually resolved to the value last changed by any IDE."
          ],
          "default": "merge",
          "description": "Strategy for resolving settings.json conflicts across IDEs."
        },
        "vscode-forks-sync.settings.excludeKeys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "telemetry.enableTelemetry",
            "update.channel",
            "extensions.autoUpdate",
            "vscode-forks-sync.*"
          ],
          "description": "Settings keys excluded from sync. Supports glob patterns like 'editor.*'. Excluded keys are always kept local."
        },
        "vscode-forks-sync.settings.includeKeys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Optional settings whitelist. When non-empty, only matching keys participate in sync; all other keys stay local. Supports glob patterns like 'editor.*'."
        },
        "vscode-forks-sync.settings.pokaYokeThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "Ask for confirmation before applying a settings pull that would overwrite this many synced keys or more."
        },
        "vscode-forks-sync.backupBeforeLocalWrite": {
          "type": "boolean",
          "default": true,
          "description": "Create a per-IDE backup before writing local settings.json or keybindings.json. Restore is manual."
        },
        "vscode-forks-sync.extensions.excludeExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extension IDs excluded from sync. Supports glob patterns and is matched case-insensitively."
        },
        "vscode-forks-sync.extensionsGallery": {
          "type": "object",
          "description": "Open VSX-compatible gallery used for VSIX lookup. Fork Sync currently uses serviceUrl for Open VSX-style registries and falls back to VS Marketplace.",
          "default": {
            "serviceUrl": "https://open-vsx.org/vscode/gallery",
            "itemUrl": "https://open-vsx.org/vscode/item"
          },
          "properties": {
            "serviceUrl": {
              "type": "string"
            },
            "itemUrl": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "dev": "pnpm build --watch --sourcemap",
    "build": "tsdown",
    "package": "vsce package --no-dependencies",
    "generate": "vscode-ext-gen --output src/generated/meta.ts",
    "prepare": "pnpm generate",
    "prepublishOnly": "pnpm build",
    "vscode:prepublish": "pnpm build",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "update": "taze major -r"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "^3.7.1",
    "comment-json": "^4.6.2",
    "eslint": "^9.39.4",
    "micromatch": "^4.0.8",
    "ofetch": "^1.5.1",
    "reactive-vscode": "^0.4.1",
    "taze": "^19.11.0",
    "tsdown": "^0.18.4",
    "typescript": "^5.9.3",
    "vscode-ext-gen": "^1.6.0"
  }
}
