{
  "publisher": "lexatang",
  "name": "vscode-forks-sync",
  "displayName": "%name%",
  "version": "0.2.1",
  "private": false,
  "packageManager": "pnpm@10.27.0",
  "description": "%description%",
  "author": "lexatang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LexaTang/vscode-forks-sync"
  },
  "bugs": {
    "url": "https://github.com/LexaTang/vscode-forks-sync/issues"
  },
  "keywords": [
    "vscode",
    "cursor",
    "windsurf",
    "vscodium",
    "settings",
    "keybindings",
    "extensions",
    "sync"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "res/icon.png",
  "files": [
    "LICENSE.md",
    "README.md",
    "dist/*",
    "package.nls.json",
    "package.nls.zh-cn.json",
    "res/*"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscode-forks-sync.syncProfile",
        "title": "%command.syncProfile.title%",
        "category": "%command.syncProfile.category%",
        "icon": "$(sync)"
      },
      {
        "command": "vscode-forks-sync.syncSettings",
        "title": "%command.syncSettings.title%",
        "category": "%command.syncSettings.category%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "vscode-forks-sync.syncKeybindings",
        "title": "%command.syncKeybindings.title%",
        "category": "%command.syncKeybindings.category%",
        "icon": "$(keyboard)"
      },
      {
        "command": "vscode-forks-sync.syncExtensions",
        "title": "%command.syncExtensions.title%",
        "category": "%command.syncExtensions.category%",
        "icon": "$(extensions)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "%config.title%",
      "properties": {
        "vscode-forks-sync.storagePath": {
          "type": "string",
          "description": "%config.storagePath.description%",
          "default": "~/.vscode-forks-sync"
        },
        "vscode-forks-sync.autoSync": {
          "type": "boolean",
          "description": "%config.autoSync.description%",
          "default": true
        },
        "vscode-forks-sync.promptOnAutoSync": {
          "type": "boolean",
          "description": "%config.promptOnAutoSync.description%",
          "default": true
        },
        "vscode-forks-sync.promptOnExtensionSync": {
          "type": "boolean",
          "description": "%config.promptOnExtensionSync.description%",
          "default": true
        },
        "vscode-forks-sync.settings.mergeMode": {
          "type": "string",
          "enum": [
            "override",
            "merge"
          ],
          "enumDescriptions": [
            "%config.mergeMode.override%",
            "%config.mergeMode.merge%"
          ],
          "default": "merge",
          "description": "%config.mergeMode.description%"
        },
        "vscode-forks-sync.settings.excludeKeys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "telemetry.enableTelemetry",
            "update.channel",
            "extensions.autoUpdate",
            "vscode-forks-sync.*"
          ],
          "description": "%config.excludeKeys.description%"
        },
        "vscode-forks-sync.settings.includeKeys": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.includeKeys.description%"
        },
        "vscode-forks-sync.settings.pokaYokeThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "description": "%config.pokaYokeThreshold.description%"
        },
        "vscode-forks-sync.backupBeforeLocalWrite": {
          "type": "boolean",
          "default": true,
          "description": "%config.backupBeforeLocalWrite.description%"
        },
        "vscode-forks-sync.extensions.excludeExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "%config.excludeExtensions.description%"
        },
        "vscode-forks-sync.extensionsGallery": {
          "type": "object",
          "description": "%config.extensionsGallery.description%",
          "default": {
            "serviceUrl": "https://open-vsx.org/vscode/gallery",
            "itemUrl": "https://open-vsx.org/vscode/item"
          },
          "properties": {
            "serviceUrl": {
              "type": "string"
            },
            "itemUrl": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "dev": "pnpm build --watch --sourcemap",
    "build": "tsdown",
    "package": "vsce package --no-dependencies",
    "generate": "vscode-ext-gen --output src/generated/meta.ts",
    "prepare": "pnpm generate",
    "prepublishOnly": "pnpm build",
    "vscode:prepublish": "pnpm build",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "update": "taze major -r",
    "release": "pnpm lint && pnpm typecheck && bumpp"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:lint",
    "@types/micromatch": "catalog:",
    "@types/node": "catalog:conflicts_types_h25_5_2",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "catalog:cli",
    "bumpp": "catalog:cli",
    "comment-json": "catalog:conflicts_utils_h4_6_2",
    "eslint": "catalog:conflicts_lint_h9_39_4",
    "micromatch": "catalog:",
    "ofetch": "catalog:network",
    "pncat": "catalog:cli",
    "reactive-vscode": "catalog:vscode",
    "taze": "catalog:conflicts_cli_h19_11_0",
    "tsdown": "catalog:build",
    "typescript": "catalog:tsc",
    "vscode-ext-gen": "catalog:conflicts_vscode_h1_6_0"
  }
}
